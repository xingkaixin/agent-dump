---
import { site, ui, type Locale } from "../lib/i18n";
import { version } from "../lib/version";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = ui[locale];

const links = [
  { label: t.footerGithub, href: site.repo },
  { label: "npm", href: site.npm },
  { label: "PyPI", href: site.pypi },
  { label: `${t.changelogLabel} · v${version}`, href: site.changelogUrl[locale] },
];
---

<footer class="border-t border-line">
  <div class="shell flex flex-col gap-6 py-10 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="font-mono text-[15px] font-semibold text-fg">agent-dump</p>
      <p class="mt-1.5 text-[13px] text-muted">{t.footerTagline}</p>
    </div>
    <nav aria-label="Footer" class="flex flex-wrap gap-x-5 gap-y-2">
      {
        links.map((link) => (
          <a
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            class="font-mono text-[13px] text-muted no-underline transition-colors duration-150 ease-out hover:text-accent"
          >
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>
</footer>
