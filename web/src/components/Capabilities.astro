---
import { ui, type Locale } from "../lib/i18n";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = ui[locale];
---

<section id="capabilities" class="shell py-16 sm:py-20">
  <div data-reveal class="max-w-[65ch]">
    <h2 class="text-[clamp(1.35rem,3vw,1.9rem)] font-semibold tracking-[-0.01em] text-fg">
      {t.capabilitiesHeading}
    </h2>
    <p class="mt-3 text-[14.5px] leading-relaxed text-muted">{t.answerSummary}</p>
  </div>

  <div class="mt-10 border-b border-line">
    {
      t.capabilities.map((cap, i) => (
        <div
          data-reveal
          style={`--reveal-delay: ${i * 60}ms`}
          class="grid gap-x-8 gap-y-3 border-t border-line py-6 lg:grid-cols-[1fr_1.05fr] lg:items-center"
        >
          <div>
            <h3 class="font-mono text-[15.5px] font-medium text-fg">{cap.title}</h3>
            <p class="mt-1.5 max-w-[48ch] text-[14px] leading-relaxed text-muted">{cap.body}</p>
          </div>
          <div class="flex items-center gap-2.5 rounded-[var(--radius-sm)] border border-line bg-surface/50 px-3.5 py-2.5">
            <span aria-hidden="true" class="select-none font-mono text-[13px] text-accent">
              $
            </span>
            <code class="overflow-x-auto whitespace-nowrap font-mono text-[13px] text-fg">
              {cap.command}
            </code>
          </div>
        </div>
      ))
    }
  </div>
</section>
