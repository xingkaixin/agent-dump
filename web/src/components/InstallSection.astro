---
import { install, site, ui, type Locale } from "../lib/i18n";
import { InstallTabs } from "./InstallTabs";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = ui[locale];

const groups = [
  { label: install.globalLabel[locale], tabs: install.global },
  { label: install.runLabel[locale], tabs: install.run },
];
---

<section id="install" class="shell py-16 sm:py-20">
  <div data-reveal class="max-w-[46ch]">
    <h2 class="text-[clamp(1.35rem,3vw,1.9rem)] font-semibold tracking-[-0.01em] text-fg">
      {t.installHeading}
    </h2>
    <p class="mt-3 text-[14.5px] leading-relaxed text-muted">{t.installNote}</p>
  </div>

  <div data-reveal class="mt-10 max-w-[42rem]">
    <InstallTabs
      client:visible
      groups={groups}
      skill={{ note: t.skillNote, command: site.skillCommand }}
      copy={t.copy}
      copied={t.copied}
    />
  </div>
</section>
