---
import { site, ui, type Locale } from "../lib/i18n";
import { Icon } from "astro-icon/components";

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = ui[locale];

const langs: { code: Locale; label: string }[] = [
  { code: "en", label: "EN" },
  { code: "zh", label: "中文" },
];
---

<header
  class="sticky top-0 z-40 border-b border-line bg-bg/80 backdrop-blur-md supports-[backdrop-filter]:bg-bg/70"
>
  <div class="shell flex h-16 items-center justify-between">
    <a
      href={site.paths[locale]}
      class="group inline-flex items-center gap-2.5 no-underline"
    >
      <img
        src={site.logo}
        alt=""
        width="26"
        height="26"
        class="rounded-[var(--radius-xs)]"
      />
      <span class="font-mono text-[15px] font-semibold tracking-tight text-fg">agent-dump</span>
    </a>

    <div class="flex items-center gap-2.5">
      <div
        role="group"
        aria-label={t.langLabel}
        class="inline-flex overflow-hidden rounded-[var(--radius-sm)] border border-line"
      >
        {
          langs.map((lang) => {
            const current = lang.code === locale;
            return (
              <a
                href={site.paths[lang.code]}
                lang={lang.code === "zh" ? "zh-Hans" : "en"}
                aria-current={current ? "page" : undefined}
                class:list={[
                  "px-2.5 py-1.5 font-mono text-[12px] no-underline transition-colors duration-150 ease-out",
                  current
                    ? "bg-fg text-bg"
                    : "text-muted hover:bg-surface hover:text-fg",
                ]}
              >
                {lang.label}
              </a>
            );
          })
        }
      </div>

      <div class="size-9 shrink-0">
        <button
          type="button"
          data-theme-toggle
          aria-label={t.themeLabel}
          title={t.themeLabel}
          class="grid size-9 cursor-pointer place-items-center rounded-[var(--radius-sm)] border border-line text-muted transition-[transform,color,background-color,border-color] duration-150 ease-out hover:border-line-strong hover:text-fg active:scale-95"
        >
          <span class="relative block size-[18px]">
            <Icon
              name="ph:sun-bold"
              aria-hidden="true"
              class="absolute inset-0 size-[18px] transition-[opacity,transform] duration-200 ease-out dark:scale-60 dark:-rotate-90 dark:opacity-0"
            />
            <Icon
              name="ph:moon-bold"
              aria-hidden="true"
              class="absolute inset-0 size-[18px] rotate-90 scale-60 text-accent opacity-0 transition-[opacity,transform] duration-200 ease-out dark:rotate-0 dark:scale-100 dark:opacity-100"
            />
          </span>
        </button>
      </div>
    </div>
  </div>
</header>

<script is:inline>
  document.querySelectorAll("[data-theme-toggle]").forEach(function (button) {
    button.addEventListener("click", function () {
      var root = document.documentElement;
      var next = root.getAttribute("data-theme") === "dark" ? "light" : "dark";
      if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        root.classList.add("theme-transition");
        window.setTimeout(function () {
          root.classList.remove("theme-transition");
        }, 260);
      }
      root.setAttribute("data-theme", next);
      var meta = document.querySelector('meta[name="theme-color"]');
      if (meta) meta.setAttribute("content", next === "dark" ? "#141109" : "#faf8f4");
      try {
        localStorage.setItem("agent-dump-theme", next);
      } catch (e) {}
    });
  });
</script>
